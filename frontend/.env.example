# =============================================================================
# Chimera Dungeon Frontend — Environment Variables
# =============================================================================
# Copy to .env and edit as needed.
# In development, the Vite proxy handles /api and /ws routing so these are
# only used as fallbacks. In production builds, these values are baked in.
# =============================================================================

# Backend REST API base URL (fallback when Vite proxy is unavailable)
VITE_API_URL=http://localhost:8000

# Backend WebSocket URL (fallback when Vite proxy is unavailable)
VITE_WS_URL=ws://localhost:8000/ws
