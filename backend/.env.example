# =============================================================================
# MistralWorld .env.example
# =============================================================================
# Copy to .env and edit as needed. All variables have sensible defaults.
# For local development with ollama + whisper.cpp, no API keys are required.
# =============================================================================

# --- Local Inference Endpoints ---
MISTRAL_ENDPOINT=http://localhost:11434
MISTRAL_MODEL=mistral:7b-instruct-v0.3-q4_K_M
WHISPER_MODEL=base.en
WHISPER_BASE_URL=http://localhost:8787
# MISTRAL_API_KEY=              # Only needed for remote Mistral API
# STT_API_KEY=                  # Only needed for remote ElevenLabs
# STT_PROVIDER=whisper_local    # Options: whisper_local, voxtral, elevenlabs

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Game ---
# TICK_RATE=20
# SESSION_TIMEOUT_MINUTES=30
# MAX_SESSIONS=1                # Default 1 for local CPU inference
# MAX_SESSIONS_PER_IP=1

# --- AI Tuning ---
# AI_TIMEOUT_SECONDS=30.0
# STT_TIMEOUT_SECONDS=10.0
# AI_MAX_RETRIES=1
# AI_MAX_CONCURRENT=1
# AI_RETRY_DELAY_MS=500
# AI_MIN_SPACING_MS=200

# --- Audio ---
# AUDIO_MAX_SIZE_BYTES=10485760
# AUDIO_MIN_DURATION_SECONDS=0.3
# AUDIO_MAX_DURATION_SECONDS=10.0

# --- STT ---
# STT_MODEL=base.en
# STT_PROVIDER=whisper_local
# STT_ENDPOINT_ENABLED=true

# --- Ollama Process (not consumed by Python backend) ---
# OLLAMA_KEEP_ALIVE=60m
# OLLAMA_LOG_LEVEL=warn
# OLLAMA_NUM_THREADS=              # Recommended: $(nproc)/2
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_HOST=127.0.0.1:11434

# --- Deterministic Hashing ---
PYTHONHASHSEED=0

# --- Frontend (Vite) ---
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000/ws
